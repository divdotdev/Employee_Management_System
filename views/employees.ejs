<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employee Directory</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background:#f4f7f6; padding:40px 20px; color: #2c3e50; }
        .header-section { text-align:center; margin-bottom:30px; }
        h1 { font-size: 28px; margin-bottom: 15px; }
        .home-btn { display:inline-block; text-decoration:none; background:#2c3e50; color:white; padding:10px 20px; border-radius:6px; font-size: 14px; font-weight: 500; transition: background 0.2s; }
        .home-btn:hover { background:#1a252f; }
        
        .search-box { max-width: 500px; margin: 0 auto 30px auto; display: flex; gap: 10px; }
        .search-box input { flex: 1; padding: 12px; border: 1px solid #dcdde1; border-radius: 8px; font-size: 15px; outline: none; }
        .search-box button { padding: 12px 24px; background: #3498db; color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; transition: background 0.2s; }
        .search-box button:hover { background: #2980b9; }

        .container { max-width:1000px; margin:auto; display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
        .card { background:white; border-radius:12px; padding:24px; box-shadow:0 4px 16px rgba(0,0,0,0.03); display: flex; flex-direction: column; justify-content: space-between; border-top: 4px solid #3498db; }
        .card-details p { margin-bottom: 12px; font-size: 15px; color: #57606f; }
        .card-details p strong { color: #2c3e50; }
        .card-name { font-size: 20px; font-weight: 600; color: #2c3e50; margin-bottom: 15px; border-bottom: 1px solid #f1f2f6; padding-bottom: 10px; }
        
        .actions { display: flex; gap: 10px; margin-top: 15px; border-top: 1px solid #f1f2f6; padding-top: 15px; }
        .actions a { flex: 1; text-align: center; text-decoration:none; color:white; padding:10px; border-radius:6px; font-size: 14px; font-weight: 500; transition: opacity 0.2s; }
        .edit { background:#3498db; }
        .delete { background:#e74c3c; }
        .actions a:hover { opacity: 0.9; }
    </style>
</head>
<body>

    <div class="header-section">
        <h1>Employee Profiles</h1>
        <a href="/" class="home-btn">🏠 Home Dashboard</a>
    </div>

    <form action="/getdata" method="GET">
        <div class="search-box">
            <input type="text" name="department" placeholder="Search filter by department...">
            <button type="submit">Filter</button>
        </div>
    </form>

    <div class="container">
        <% allemployee.forEach((element)=>{ %>
        <div class="card">
            <div>
                <div class="card-name"><%= element.name %></div>
                <div class="card-details">
                    <p><strong>Email:</strong> <%= element.email %></p>
                    <p><strong>Dept:</strong> <%= element.department %></p>
                    <p><strong>Salary:</strong> $<%= element.salary.toLocaleString() %></p>
                    <p><strong>Experience:</strong> <%= element.experience %> Years</p>
                </div>
            </div>
            <div class="actions">
                <a href="/edit/<%= element._id %>" class="edit">Modify</a>
                <a href="/delete/<%= element._id %>" class="delete">Remove</a>
            </div>
        </div>
        <% }) %>
    </div>

</body>
</html>