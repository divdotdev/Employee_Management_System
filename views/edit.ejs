<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Employee</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background: #f4f7f6; padding: 40px 20px; display: flex; justify-content: center; }
        .form-container { background: white; padding: 35px; border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,0.05); max-width: 500px; width: 100%; }
        h2 { color: #2c3e50; margin-bottom: 24px; font-size: 24px; text-align: center; }
        .form-group { margin-bottom: 20px; }
        label { display: block; margin-bottom: 8px; color: #7f8c8d; font-size: 14px; font-weight: 500; }
        input { width: 100%; padding: 12px; border: 1px solid #dcdde1; border-radius: 8px; font-size: 15px; outline: none; transition: border 0.2s; }
        input:focus { border-color: #3498db; }
        .btn-submit { width: 100%; padding: 14px; background: #3498db; color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: 600; cursor: pointer; transition: background 0.2s; }
        .btn-submit:hover { background: #2980b9; }
        .back-link { display: block; text-align: center; margin-top: 15px; color: #7f8c8d; text-decoration: none; font-size: 14px; }
        .back-link:hover { color: #2c3e50; }
    </style>
</head>
<body>
    <div class="form-container">
        <h2>Update Details</h2>
        <form action="/update/<%=data._id%>" method="POST">
            <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="name" value="<%=data.name%>" required>
            </div>
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" name="email" value="<%=data.email%>" required>
            </div>
            <div class="form-group">
                <label>Department</label>
                <input type="text" name="department" value="<%=data.department%>" required>
            </div>
            <div class="form-group">
                <label>Annual Salary ($)</label>
                <input type="number" name="salary" value="<%=data.salary%>" required>
            </div>
            <div class="form-group">
                <label>Years of Experience</label>
                <input type="number" name="experience" value="<%=data.experience%>" required>
            </div>
            <button type="submit" class="btn-submit">Update Employee</button>
        </form>
        <a href="/getdata" class="back-link">Cancel Changes</a>
    </div>
</body>
</html>